# AI Provider Configuration
# Set at least one of the following API keys.
# OpenRouter is the default (free-tier models, no cost for demos).
# If both are set, OpenRouter takes priority.

OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: fall back to OpenAI if OPENROUTER_API_KEY is not set
# OPENAI_API_KEY=your_openai_api_key_here
